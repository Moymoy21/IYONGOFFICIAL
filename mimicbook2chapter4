RunService.Heartbeat:Connect(function()
    -- Check kung naka-ON ang toggle at kung buhay ang player
    if not _G.AutoSafeTP or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local myPos = player.Character.HumanoidRootPart.Position
    for _, monsterName in pairs(targetMonsters) do
        local monster = workspace:FindFirstChild(monsterName)
        if monster and monster:FindFirstChild("HumanoidRootPart") then
            local distance = (monster.HumanoidRootPart.Position - myPos).Magnitude
            if distance < DETECTION_RANGE then
                player.Character.HumanoidRootPart.CFrame = SAFE_CFRAME
                task.wait(1.5)
            end
        end
    end
end)
