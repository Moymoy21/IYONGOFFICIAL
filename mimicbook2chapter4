createTab("Coin TP", function()
    local container = rightScroll -- Dito natin ilalagay ang listahan
    
    local refreshBtn = Instance.new("TextButton", container)
    refreshBtn.Size = UDim2.new(1, -20, 0, 40)
    refreshBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
    refreshBtn.Text = "Refresh Coin List"
    refreshBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", refreshBtn).CornerRadius = UDim.new(0, 8)
    
    local function refreshList()
        -- Burahin ang lumang listahan (iwanan ang refresh button)
        for _, child in pairs(container:GetChildren()) do
            if child:IsA("Frame") or (child:IsA("TextButton") and child ~= refreshBtn) then
                child:Destroy()
            end
        end
        
        -- Hanapin ang folder ng coins
        local coinFolder = workspace:FindFirstChild("Section2") 
            and workspace.Section2:FindFirstChild("Floor2") 
            and workspace.Section2.Floor2:FindFirstChild("Coins")
            
        if coinFolder then
            local counter = 1
            for _, coin in pairs(coinFolder:GetChildren()) do
                -- Gumawa ng button para sa bawat coin
                local btn = Instance.new("TextButton", container)
                btn.Size = UDim2.new(1, -20, 0, 40)
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                btn.TextColor3 = Color3.new(1, 1, 1)
                btn.Text = "Coin " .. counter .. " [ Teleport ]"
                btn.Font = Enum.Font.GothamMedium
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
                
                btn.MouseButton1Click:Connect(function()
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        -- Teleport sa posisyon ng coin
                        player.Character.HumanoidRootPart.CFrame = coin.CFrame
                    end
                end)
                counter = counter + 1
            end
        else
            local errorLabel = Instance.new("TextLabel", container)
            errorLabel.Text = "Coins folder not found!"
            errorLabel.TextColor3 = Color3.new(1, 0, 0)
            errorLabel.BackgroundTransparency = 1
        end
    end
    
    refreshBtn.MouseButton1Click:Connect(refreshList)
end)

